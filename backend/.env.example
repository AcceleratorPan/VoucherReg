# App
APP_NAME=Voucher Backend
APP_ENV=dev
DEBUG=true
API_PREFIX=

# DB
DATABASE_URL=sqlite:///./data/app.db

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./data/storage

# OCR
OCR_PROVIDER=rapidocr
RAPIDOCR_TEXT_SCORE=0.5
RAPIDOCR_USE_DET=true
RAPIDOCR_USE_CLS=true
RAPIDOCR_USE_REC=true

# Upload constraints
MAX_UPLOAD_MB=15

# Auth
AUTH_SECRET_KEY=change-me-in-production
AUTH_ISSUER=voucher-backend
AUTH_TOKEN_EXPIRE_MINUTES=1440

# WeChat auth
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_LOGIN_TIMEOUT_SECONDS=8
WECHAT_LOGIN_MOCK_ENABLED=false
WECHAT_LOGIN_MOCK_PREFIX=dev-
