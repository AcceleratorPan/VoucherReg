.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.task-count {
  font-size: 24rpx;
  color: #666;
}

.batch-btn {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #07c160;
  border: 1rpx solid #07c160;
  border-radius: 8rpx;
}

.selection-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.select-hint {
  font-size: 24rpx;
  color: #666;
}

.select-all {
  font-size: 24rpx;
  color: #07c160;
  padding: 10rpx 20rpx;
}

/* 任务列表 */
.task-list {
  flex: 1;
  height: calc(100vh - 280rpx);
  padding-bottom: 20rpx;
  box-sizing: border-box;
}

.task-list.selection-mode {
  height: calc(100vh - 260rpx);
}

.task-item {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

/* 复选框 */
.task-checkbox {
  display: flex;
  align-items: flex-start;
  padding-top: 40rpx;
  margin-right: 20rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.checkbox.checked {
  background-color: #07c160;
  border-color: #07c160;
}

/* 任务内容 */
.task-content {
  flex: 1;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.task-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.confidence {
  font-size: 22rpx;
  color: #999;
}

.form-section {
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #f9f9f9;
  box-sizing: border-box;
}

.preview-section {
  margin-bottom: 20rpx;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.preview-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.preview-text {
  display: block;
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
}

.view-image-btn {
  display: inline-block;
  padding: 10rpx 30rpx;
  font-size: 24rpx;
  color: #07c160;
  border: 1rpx solid #07c160;
  border-radius: 8rpx;
  text-align: center;
}

/* 按钮区域 */
.button-area {
  padding: 20rpx 0;
}

.button-group {
  display: flex;
  gap: 20rpx;
}

.button-group.selection-mode {
  flex-direction: column;
}

/* 底部按钮 */
.fixed-bottom-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

/* 固定底部按钮 */
.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
  padding: 0 30rpx;
  margin: 0;
}

.button::after {
  border: none;
}

.primary-button {
  background-color: #07c160;
  color: #fff;
}

.secondary-button {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #e0e0e0;
}

.cancel-btn {
  background-color: #fff;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

/* 返回首页 */
.back-home {
  padding-top: 20rpx;
  border-top: 1rpx solid #e0e0e0;
  width: 100%;
}

.back-home-button {
  background-color: #fff;
  color: #666;
  border: 1rpx solid #e0e0e0;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  width: 100%;
}
