<view class="container">
  <view class="header">
    <text class="title">批量下载</text>
    <text class="subtitle">已选择 {{taskList.length}} 个任务</text>
  </view>

  <!-- PDF 列表 -->
  <scroll-view class="pdf-list" scroll-y>
    <view class="pdf-item" wx:for="{{taskList}}" wx:key="taskId">
      <text class="pdf-name">{{item.pdfName || item.fileNamePreview || '未命名'}}</text>
    </view>
  </scroll-view>

  <!-- 操作按钮 -->
  <view class="button-group">
    <button class="button primary-button" open-type="share">
      分享 ZIP
    </button>
    <button class="button secondary-button" bindtap="goHome">
      返回首页
    </button>
    <button class="button secondary-button" bindtap="goBack">
      返回上一步
    </button>
  </view>
</view>
