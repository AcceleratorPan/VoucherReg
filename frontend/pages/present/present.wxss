.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

.content {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.url-section {
  margin-bottom: 30rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.url-box {
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 20rpx;
  word-break: break-all;
}

.url-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.loading-section {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 30rpx;
}

.tips {
  margin-top: 40rpx;
  padding: 20rpx;
  background-color: #f0f9ff;
  border-radius: 8rpx;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.tips-text {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}

.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
  padding: 0 30rpx;
  margin: 0;
}

.button::after {
  border: none;
}

.primary-button {
  background-color: #07c160;
  color: #fff;
}

.secondary-button {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #e0e0e0;
}
